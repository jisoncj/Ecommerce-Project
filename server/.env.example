# Server port
PORT=5000

# MongoDB Atlas connection string
# Replace with your own from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/nexus-store?retryWrites=true&w=majority

# JWT secret — use any random string (keep it secret!)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Stripe keys (test mode) — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
